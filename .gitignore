.vs/
*.sln
*.csproj
*.csproj.user
ExportedObj/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# Rider / JetBrains
.idea/
*.DotSettings.user

# VS Code
.vscode/

